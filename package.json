{
  "name": "@op4z/flint",
  "version": "1.0.1",
  "description": "Flint — the Cloudflare Pages bootstrap CLI. Sparks the spark for Vite + React + TS apps on Cloudflare Pages.",
  "type": "module",
  "license": "MIT",
  "author": "Beau Goldberg",
  "homepage": "https://github.com/op4z-labs/flint",
  "repository": {
    "type": "git",
    "url": "https://github.com/op4z-labs/flint.git"
  },
  "bugs": {
    "url": "https://github.com/op4z-labs/flint/issues"
  },
  "bin": {
    "flint": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/cloudflare tests/commands tests/templates tests/util",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "prepare": "npm run build"
  },
  "keywords": [
    "cloudflare",
    "pages",
    "wrangler",
    "vite",
    "react",
    "typescript",
    "cli",
    "bootstrap",
    "scaffold"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "commander": "^12.1.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.17.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.6"
  }
}
