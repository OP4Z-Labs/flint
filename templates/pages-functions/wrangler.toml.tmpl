# Generated by flint@{{flintVersion}} — run `flint upgrade --check` for drift.
# Edit freely. See https://developers.cloudflare.com/workers/wrangler/configuration/
name = "{{appName}}"
pages_build_output_dir = "dist"
compatibility_date = "{{compatDate}}"
compatibility_flags = ["nodejs_compat"]

# KV namespace for content, waitlist entries, rate-limit counters.
# `preview_id` reuses the same namespace so local `wrangler pages dev`
# sees the same data — flip it to a separate id for preview isolation.
#
# After `flint configure` runs, the placeholder id below is replaced with
# the real one. Until then `wrangler pages dev` will warn about an
# unresolved binding.
[[kv_namespaces]]
binding = "CONTENT_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
preview_id = "REPLACE_WITH_KV_NAMESPACE_ID"

# Secrets live in the Cloudflare Pages dashboard OR via CLI:
#   npm run secret:set ADMIN_PASSWORD
#   npm run secret:set COOKIE_SECRET
