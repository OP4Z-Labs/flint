/// <reference types="vitest/config" />
import { defineConfig } from 'vite'
import react from '@vitejs/plugin-react'
import tailwindcss from '@tailwindcss/vite'
import { VitePWA } from 'vite-plugin-pwa'

// Vite serves the React app only. Pages Functions in `functions/` are executed
// by `wrangler pages dev`, which proxies to Vite for static assets.
// See package.json — `npm run dev` runs both concurrently. The combined entry
// point the browser hits is http://localhost:8788 (wrangler), which then
// proxies non-Function requests to http://localhost:5173 (vite HMR).
//
// PWA: the plugin owns the manifest so it stays in sync with the precache
// list. Runtime caching strategies below define how the SW handles requests
// after install — tune these to your app's traffic patterns.

export default defineConfig({
  plugins: [
    react(),
    tailwindcss(),
    VitePWA({
      registerType: 'autoUpdate',
      injectRegister: 'auto',
      includeAssets: [
        'favicon.svg',
        'favicon-16.png',
        'favicon-32.png',
        'apple-touch-icon.png',
      ],
      manifest: {
        name: '{{appName}}',
        short_name: '{{appName}}',
        description: '{{appName}} — generated by Flint.',
        start_url: '/',
        scope: '/',
        display: 'standalone',
        background_color: '#0e0c0a',
        theme_color: '#0e0c0a',
        icons: [
          { src: '/icon-192.png', sizes: '192x192', type: 'image/png', purpose: 'any' },
          { src: '/icon-512.png', sizes: '512x512', type: 'image/png', purpose: 'any' },
          { src: '/icon-maskable-512.png', sizes: '512x512', type: 'image/png', purpose: 'maskable' },
        ],
      },
      workbox: {
        globPatterns: ['**/*.{js,css,html,svg,png,ico,woff,woff2,ttf}'],
        navigateFallback: '/index.html',
        // Don't intercept admin/API write paths — those need to fail hard
        // offline so the user knows their edits didn't save.
        navigateFallbackDenylist: [/^\/api\//, /^\/admin\//],
      },
      devOptions: { enabled: false },
    }),
  ],
  resolve: {
    alias: { '@': '/src' },
  },
  server: {
    // If you hit :5173 directly, forward `/api/*` to wrangler on :8788 so
    // Functions resolve correctly and the admin doesn't get the SPA fallback.
    proxy: {
      '/api': { target: 'http://localhost:8788', changeOrigin: true },
    },
  },
})
