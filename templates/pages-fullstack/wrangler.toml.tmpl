# Generated by Flint. Edit freely — Flint will warn before overwriting on
# `flint upgrade`. See https://developers.cloudflare.com/workers/wrangler/configuration/
name = "{{appName}}"
pages_build_output_dir = "dist"
compatibility_date = "{{compatDate}}"
compatibility_flags = ["nodejs_compat"]

# KV namespace for content metadata, indexes, rate-limit counters.
# `preview_id` reuses the same namespace so local `wrangler pages dev`
# sees the same data — flip it to a separate id for preview isolation.
#
# After `flint configure` runs, the placeholder ids below are replaced with
# the real ones. Until then `wrangler pages dev` will warn about an
# unresolved binding.
[[kv_namespaces]]
binding = "CONTENT_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
preview_id = "REPLACE_WITH_KV_NAMESPACE_ID"

# R2 bucket for media uploads (photos, files, generated assets).
# `bucket_name` must be globally unique within your Cloudflare account.
[[r2_buckets]]
binding = "MEDIA_BUCKET"
bucket_name = "{{appNameLower}}-media"

# Secrets live in the Cloudflare Pages dashboard OR via CLI:
#   npm run secret:set ADMIN_PASSWORD
#   npm run secret:set COOKIE_SECRET
