{
  "name": "{{appName}}",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:vite": "vite --port 5173",
    "dev:cf": "wrangler pages dev --proxy 5173 --port 8788",
    "dev": "concurrently -n vite,cf -c cyan,magenta \"npm:dev:vite\" \"npm:dev:cf\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && wrangler pages deploy",
    "deploy:preview": "npm run build && wrangler pages deploy --branch=preview",
    "logs": "wrangler pages deployment tail --project-name={{appName}}",
    "deployments": "wrangler pages deployment list --project-name={{appName}}",
    "secrets": "wrangler pages secret list --project-name={{appName}}",
    "secret:set": "wrangler pages secret put --project-name={{appName}}",
    "whoami": "wrangler whoami"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.90.0"
  }
}
