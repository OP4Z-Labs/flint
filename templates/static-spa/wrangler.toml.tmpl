# Generated by flint@{{flintVersion}} — run `flint upgrade --check` for drift.
# Edit freely. See https://developers.cloudflare.com/workers/wrangler/configuration/
name = "{{appName}}"
pages_build_output_dir = "dist"
compatibility_date = "{{compatDate}}"
compatibility_flags = ["nodejs_compat"]

# {{appName}} is a static SPA — no KV bindings, no R2, no Pages Functions.
# wrangler is here only to run `wrangler pages deploy` against a Pages
# project named `{{appName}}`. The first deploy needs the project to be
# created:
#
#   flint configure                # interactive — Flint will create it
#   wrangler pages project create {{appName}} --production-branch main
